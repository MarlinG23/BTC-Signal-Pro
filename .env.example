# ──────────────────────────────────────────────────────────────────────────────
# BTC Signal Pro — Environment Variables
# Copy this file to .env and fill in your values before running locally.
# On Railway, set these in each service's Variables tab.
# ──────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver required for the async backend).
# Railway auto-injects this when you link a Postgres service — the app will
# automatically rewrite postgres:// → postgresql+asyncpg://.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/btc_signals


# ── Binance ───────────────────────────────────────────────────────────────────
# API keys are defined but NOT currently used — the app uses public WebSocket
# streams only. Leave blank unless you add authenticated endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set true to use Binance testnet WebSocket instead of live streams.
BINANCE_TESTNET=false

# Use binance.us instead of binance.com WebSocket/REST endpoints.
# Required on US-based cloud servers (Railway US West) — binance.com
# returns HTTP 451 (geo-blocked) from US infrastructure.
BINANCE_USE_US_ENDPOINT=true


# ── App ───────────────────────────────────────────────────────────────────────
# Environment name: development | production | test
APP_ENV=development

# Host and port for the uvicorn server (Railway overrides PORT via $PORT).
APP_HOST=0.0.0.0
APP_PORT=8000

# Comma-separated list of allowed CORS origins.
# Set to your frontend URL in production, or * to allow all (default).
CORS_ORIGINS=http://localhost:3000


# ── Signal Engine ─────────────────────────────────────────────────────────────
# Minimum confidence % (0–100) required for a signal to fire.
SIGNAL_CONFIDENCE_THRESHOLD=60.0

# Minimum number of indicator votes that must agree for a signal to fire.
SIGNAL_MIN_INDICATORS=2

# Minimum candles buffered before signal evaluation starts (noise gate).
SIGNAL_MIN_CANDLES=3

# Minimum candles before liquidation alert fires (USD millions threshold).
LIQUIDATION_ALERT_THRESHOLD_M=500.0


# ── Firebase (optional — enables mobile push notifications) ───────────────────
# Create a Firebase project → Project Settings → Service Accounts →
# Generate new private key → copy values from the downloaded JSON file.
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
# Paste the private key as a single line with literal \n characters.
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=


# ── Third-party data APIs (all optional) ─────────────────────────────────────
# CoinDesk API key — currently unused (RSS feeds require no key).
COINDESK_API_KEY=

# Glassnode on-chain metrics (fetch_glassnode_price is implemented but not
# wired into the main loop yet — add your key to enable it).
GLASSNODE_API_KEY=

# CoinGlass liquidation data — enables liquidation alerts.
# Get a free key at https://coinglass.com/pricing
COINGLASS_API_KEY=


# ── Frontend (Vite — baked in at BUILD TIME) ──────────────────────────────────
# These are only needed if you build the frontend as a standalone static app
# pointed at a separate backend. When using the nginx reverse-proxy setup
# (default Railway deployment), these are NOT needed — nginx handles routing.

# Base URL of the backend REST API, e.g. https://your-backend.railway.app
# Leave empty to use same-origin (i.e. behind the nginx proxy).
VITE_API_URL=

# WebSocket URL of the backend, e.g. wss://your-backend.railway.app/ws
# Leave empty to auto-detect from window.location (nginx proxy handles it).
VITE_WS_URL=
